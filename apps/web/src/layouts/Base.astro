---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/tokens.css';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
  /**
   * When true, the page participates in the light/dark theme shared with the
   * docs (same `starlight-theme` localStorage key). When false, the page stays
   * pitch black — the brand surface (landing).
   */
  themeable?: boolean;
}
const { title, description, image, jsonLd, themeable = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo title={title} description={description} image={image} jsonLd={jsonLd} />
    {
      themeable && (
        <script is:inline>{`
          try {
            var t = localStorage.getItem('starlight-theme');
            document.documentElement.dataset.theme = t === 'light' ? 'light' : 'dark';
          } catch (e) {
            document.documentElement.dataset.theme = 'dark';
          }
        `}</script>
      )
    }
  </head>
  <body>
    <slot />
    <style is:global>
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a {
        color: var(--green);
      }
      ::selection {
        background: var(--green-tint);
      }
      :focus-visible {
        outline: 2px solid var(--green);
        outline-offset: 2px;
      }
    </style>
  </body>
</html>
