---
import Base from '../layouts/Base.astro';
import ThemeSwitch from '../components/starlight/ThemeSwitch.astro';
import Playground from '../components/playground/Playground.tsx';

const title = 'Playground — Tactile keyboard shortcuts';
const description =
  'Operate a mini app entirely with keyboard shortcuts, live in your browser: command palette, sequences, scoped bindings, collision resolution — all running the real @tactile-js engine.';
---

<Base title={title} description={description} themeable>
  <div class="pgpage">
    <header class="pgbar">
      <div class="pgbar__left">
        <a class="pgbar__brand" href="/">tactile<span aria-hidden="true">▊</span></a>
        <span class="pgbar__sep" aria-hidden="true">/</span>
        <h1 class="pgbar__title">Playground</h1>
      </div>
      <nav class="pgbar__links" aria-label="Site">
        <a href="/getting-started/introduction/">Docs</a>
        <a href="https://github.com/tactile-js/tactile">GitHub</a>
        <ThemeSwitch />
      </nav>
    </header>
    <Playground client:only="react">
      <p slot="fallback" class="pgx-muted" style="padding: 0 1.5rem;">Loading playground…</p>
    </Playground>
  </div>
</Base>

<style>
  .pgpage {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  /* One slim bar, cohesive with the docs shell. The --sl-* shims feed the
     ThemeSwitch component, which was built against Starlight's variables. */
  .pgbar {
    --sl-color-gray-6: var(--surface-2);
    --sl-color-gray-4: var(--text-dim);
    --sl-color-gray-3: var(--text-mute);
    --sl-color-hairline: var(--border);
    --sl-color-text-accent: var(--green);
    --sl-color-white: var(--text);

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--maxw);
    width: 100%;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
  }
  .pgbar__left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .pgbar__brand {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
  }
  .pgbar__brand span {
    color: var(--green);
  }
  .pgbar__sep {
    color: var(--text-mute);
    font-family: var(--font-mono);
  }
  .pgbar__title {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--text-dim);
    margin: 0;
  }
  .pgbar__links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .pgbar__links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    text-decoration: none;
  }
  .pgbar__links a:hover {
    color: var(--text);
  }
  @media (max-width: 900px) {
    .pgpage {
      height: auto;
      overflow: visible;
    }
  }
</style>

<style is:global>
  /* ── Playground root: app + inspector rail, fixed to viewport ───── */
  .pgx {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: 1fr min(360px, 35%);
    gap: 1rem;
    max-width: var(--maxw);
    width: 100%;
    margin: 0 auto;
    padding: 0 1.5rem 1.25rem;
  }
  .pgx kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.1em 0.45em;
    background: var(--surface-2);
    border: 1px solid var(--border-strong);
    border-bottom-width: 3px;
    border-radius: 5px;
    color: var(--text);
    white-space: nowrap;
  }
  .pgx code {
    font-family: var(--font-mono);
    color: var(--green);
    font-size: 0.9em;
  }
  .pgx-accent {
    color: var(--green);
  }
  .pgx-muted {
    color: var(--text-mute);
    font-size: 0.85rem;
    margin: 0;
  }

  /* ── Mini app ───────────────────────────────────────────────────── */
  .pgx-app {
    display: grid;
    grid-template-columns: 170px 1fr;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: 0;
  }
  .pgx-side {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.75rem 0.5rem;
    border-right: 1px solid var(--border);
    background: var(--bg-deep);
    min-height: 0;
  }
  .pgx-side__head {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    margin: 0 0 0.5rem;
    padding: 0 0.5rem;
  }
  .pgx-side__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4rem 0.6rem;
    background: none;
    border: none;
    border-radius: 6px;
    color: var(--text-dim);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    text-align: left;
    cursor: pointer;
  }
  .pgx-side__item:hover {
    background: var(--surface-2);
    color: var(--text);
  }
  .pgx-side__item.is-active {
    background: var(--green-tint);
    color: var(--green-bright);
  }
  .pgx-side__item.is-active kbd {
    border-color: var(--green-dim);
    color: var(--green-bright);
  }
  .pgx-side__foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-top: 1px solid var(--border);
    padding-top: 0.5rem;
  }
  .pgx-main {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .pgx-title {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    padding: 0.85rem 1.1rem;
  }
  .pgx-title:focus {
    outline: none;
    border-bottom-color: var(--amber);
  }
  .pgx-editor {
    flex: 1;
    min-height: 0;
    overflow: auto;
    padding: 1rem 1.1rem;
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.7;
    cursor: text;
  }
  .pgx-editor:focus {
    outline: none;
    color: var(--text);
    box-shadow: inset 2px 0 0 var(--green);
  }
  .pgx-status {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1.1rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-mute);
  }
  .pgx-status b {
    font-weight: 500;
    color: var(--text-dim);
  }
  .pgx-status__typing {
    color: var(--amber);
  }
  .pgx-status__save {
    margin-left: auto;
  }

  /* ── Inspector rail ─────────────────────────────────────────────── */
  .pgx-rail {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 0;
    overflow: auto;
  }
  .pgx-rail section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 0.8rem 1rem;
  }
  .pgx-rail h3 {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    font-weight: 500;
    margin: 0 0 0.6rem;
  }
  .pgx-kv {
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }
  .pgx-kv div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .pgx-kv dt {
    color: var(--text-mute);
    font-size: 0.78rem;
  }
  .pgx-kv dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .pgx-rail__activity ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }
  .pgx-adv {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .pgx-adv summary {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    padding: 0.8rem 1rem;
    cursor: pointer;
    user-select: none;
  }
  .pgx-adv section {
    border: none;
    border-top: 1px solid var(--border);
    border-radius: 0;
  }
  .pgx-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-dim);
    cursor: pointer;
    margin-bottom: 0.6rem;
  }
  .pgx-adv__list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.78rem;
    color: var(--text-dim);
    display: grid;
    gap: 0.3rem;
  }
  .pgx-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.45rem 0.8rem;
    background: var(--surface-2);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    color: var(--text);
    cursor: pointer;
  }
  .pgx-btn:hover {
    border-color: var(--green-dim);
  }
  .pgx-adv__rec {
    margin: 0.6rem 0 0;
    font-size: 0.85rem;
  }

  /* ── Overlays (palette + help) ──────────────────────────────────── */
  .pgx-overlay {
    position: fixed;
    inset: 0;
    background: rgba(1, 4, 9, 0.75);
    display: grid;
    place-items: start center;
    padding-top: 12vh;
    z-index: 50;
    backdrop-filter: blur(2px);
  }
  .pgx-palette,
  .pgx-help {
    width: min(540px, 92vw);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.6);
    overflow: hidden;
  }
  .pgx-palette input {
    width: 100%;
    box-sizing: border-box;
    border: none;
    border-bottom: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    font-family: var(--font-sans);
  }
  .pgx-palette input:focus {
    outline: none;
  }
  .pgx-palette ul {
    list-style: none;
    margin: 0;
    padding: 0.3rem 0;
    max-height: 300px;
    overflow: auto;
  }
  .pgx-palette li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 1rem;
    font-size: 0.9rem;
    color: var(--text-dim);
    cursor: pointer;
  }
  .pgx-palette li.is-active {
    background: var(--green-tint);
    color: var(--text);
  }
  .pgx-help header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .pgx-help header .pgx-toggle {
    margin: 0;
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }
  .pgx-help__body {
    padding: 0.75rem 1rem 1rem;
    max-height: 60vh;
    overflow: auto;
  }
  .pgx-help__body h4 {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    margin: 0.75rem 0 0.4rem;
    font-weight: 500;
  }
  .pgx-help__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.3rem 0;
    font-size: 0.88rem;
    color: var(--text-dim);
  }
  .pgx-help__row kbd {
    margin-left: 6px;
  }
  .pgx-when {
    font-size: 0.72rem;
    color: var(--text-mute);
    background: var(--surface-2);
    padding: 0.05rem 0.35rem;
    border-radius: 4px;
    margin-left: 0.5rem;
  }
  .pgx-help__note {
    margin-top: 1rem;
    font-size: 0.78rem;
  }

  /* ── Responsive: stack below 900px, allow scroll ────────────────── */
  @media (max-width: 900px) {
    .pgx {
      grid-template-columns: 1fr;
      overflow: visible;
    }
    .pgx-app {
      grid-template-columns: 1fr;
      min-height: 60vh;
    }
    .pgx-side {
      flex-direction: row;
      flex-wrap: wrap;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .pgx-side__head {
      display: none;
    }
    .pgx-side__foot {
      margin-top: 0;
      border-top: none;
      padding-top: 0;
      flex-direction: row;
    }
    .pgx-rail {
      overflow: visible;
    }
  }
</style>
